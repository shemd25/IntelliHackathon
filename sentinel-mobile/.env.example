# Backend WebSocket URL (ws:// for local, wss:// for production)
EXPO_PUBLIC_WS_URL=ws://YOUR_WINDOWS_LAN_IP:8080/ws/sensor

# Backend REST API URL — use Windows LAN IP (e.g. 192.168.1.42), NOT the WSL2 172.x.x.x address
EXPO_PUBLIC_API_URL=http://YOUR_WINDOWS_LAN_IP:8080

# Demo credentials (parent who owns the child device)
EXPO_PUBLIC_DEMO_EMAIL=parent@sentinel.dev
EXPO_PUBLIC_DEMO_PASSWORD=sentinel123
