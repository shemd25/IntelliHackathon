# ═══════════════════════════════════════════════════════
# SENTINEL BACKEND — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── Server ────────────────────────────────────────────
SERVER_PORT=8080

# ─── PostgreSQL ────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sentinel
DB_USER=sentinel
DB_PASS=sentinel

# ─── Redis ─────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# ─── Kafka ─────────────────────────────────────────────
# Local: localhost:9092
# Confluent Cloud: pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ─── JWT ───────────────────────────────────────────────
# CHANGE THIS in production — must be at least 256 bits (32+ chars)
JWT_SECRET=sentinelHackathonSuperSecretKeyThatIsAtLeast256BitsLong2026!
JWT_EXPIRATION_MS=86400000
