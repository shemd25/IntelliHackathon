# =========================================================
# SENTINEL BACKEND — Environment Variables
# Copy this file to .env and fill in your values.
# Local dev defaults are already in application.yml.
# =========================================================

# --- Server ---
SERVER_PORT=8080

# --- PostgreSQL ---
# Local docker-compose: localhost:5433
# Supabase: db.xxxx.supabase.co:5432
DB_HOST=localhost
DB_PORT=5433
DB_NAME=sentinel
DB_USER=sentinel
DB_PASS=sentinel

# --- Redis ---
# Local docker-compose: localhost:6379
# Upstash: redis://default:<password>@xxx.upstash.io:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASS=

# --- Kafka ---
# Local docker-compose:
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SECURITY_PROTOCOL=PLAINTEXT
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SASL_JAAS_CONFIG=

# Confluent Cloud example:
# KAFKA_BOOTSTRAP_SERVERS=pkc-xxxxx.us-east-1.aws.confluent.cloud:9092
# KAFKA_SECURITY_PROTOCOL=SASL_SSL
# KAFKA_SASL_MECHANISM=PLAIN
# KAFKA_SASL_JAAS_CONFIG=org.apache.kafka.common.security.plain.PlainLoginModule required username="<KEY>" password="<SECRET>";

# --- JWT ---
# CHANGE THIS in production — must be at least 256 bits (32+ chars)
JWT_SECRET=sentinelHackathonSuperSecretKeyThatIsAtLeast256BitsLong2026!
JWT_EXPIRATION_MS=86400000

# --- CORS ---
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173
